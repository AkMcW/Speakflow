# ============================================
# SpeakFlow AI — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your keys.
# NEVER commit .env.local to git.

# --------------------------------------------
# OpenAI (Required — powers all AI features)
# Get it: https://platform.openai.com/api-keys
# --------------------------------------------
OPENAI_API_KEY=sk-...

# --------------------------------------------
# Neon PostgreSQL (Required — database)
# Get it: https://neon.tech → New Project → Connection string
# --------------------------------------------
DATABASE_URL=postgresql://user:password@host.neon.tech/speakflow?sslmode=require

# --------------------------------------------
# Clerk (Required — authentication)
# Get it: https://clerk.com → New Application
# --------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --------------------------------------------
# Stripe (Required — payments)
# Get it: https://dashboard.stripe.com → Developers → API keys
# --------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Price IDs (create products in Stripe dashboard first)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PRO_PLUS=price_...
STRIPE_PRICE_TEAM=price_...

# --------------------------------------------
# Optional — Alternative Speech-to-Text
# --------------------------------------------
# Deepgram (faster/cheaper STT alternative to Whisper)
# Get it: https://deepgram.com
# DEEPGRAM_API_KEY=...

# --------------------------------------------
# Optional — Premium Voice
# --------------------------------------------
# ElevenLabs (high-quality AI examiner voice)
# Get it: https://elevenlabs.io
# ELEVENLABS_API_KEY=...

# --------------------------------------------
# Optional — Analytics
# --------------------------------------------
# PostHog
# Get it: https://posthog.com
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --------------------------------------------
# App Config
# --------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAIL=akedezign@gmail.com
